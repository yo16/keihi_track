{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(bd:*)",
      "Bash(bd update:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run start:*)",
      "Bash(npm run dev:*)",
      "Bash(npx jest:*)",
      "Bash(npx next:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(npx supabase:*)",
      "Bash(npm ls:*)",
      "Read(tmp/**)",
      "Write(tmp/**)",
      "Edit(tmp/**)",
      "Bash(ls tmp:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx next lint --quiet 2>&1 || true"
          }
        ]
      }
    ]
  }
}
