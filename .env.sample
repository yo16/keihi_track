# Supabase
# ダッシュボード > Project Settings > API Keys から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# アプリケーションのベースURL（招待リンクのリダイレクト先として使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 組織作成パスワード（組織新規作成時の簡易ゲート）
ORG_CREATION_PASSWORD=

# Preview環境のBasic認証パスワード（設定時のみ有効、本番では空のままにする）
# ユーザー名は任意（例: preview）、パスワードはこの値
PREVIEW_AUTH_PASSWORD=

# Resend（メール通知送信用）
# https://resend.com/api-keys から取得
RESEND_API_KEY=
